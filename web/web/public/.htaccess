<IfModule mod_rewrite.c>
    RewriteEngine On

    # 1) Force HTTPS and canonical non-www host
    RewriteCond %{HTTPS} !=on [OR]
    RewriteCond %{HTTP_HOST} ^www\.kobercemax\.sk$ [NC]
    RewriteRule ^ https://kobercemax.sk%{REQUEST_URI} [R=301,L,NE]

    # 2) Let API subtree handle its own routing via /api/.htaccess
    RewriteRule ^api(/|$) - [L]

    # 3) Serve existing files/directories directly
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # 4) Vue SPA fallback
    RewriteRule . /index.html [L]
</IfModule>
